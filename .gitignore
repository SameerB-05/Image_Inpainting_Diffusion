# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.env/
.env*/

# Dataset (keep folder, ignore contents except .gitkeep)
data/*
!data/.gitkeep

# CelebA dataset inside Phase 1 (ignore all images)
data/celeba/img_align_celeba/*

# Training checkpoints (keep folder, ignore contents except .gitkeep)
checkpoints/*
!checkpoints/.gitkeep

# Pretrained weights folder (keep folder, ignore all large files)
repaint_simplified/pretrained_weights/*
!repaint_simplified/pretrained_weights/.gitkeep

# Other model weights / large files
*.pth
*.pt
*.ckpt

# Logs / arrays
*.npy
*.npz

# Plots (optional)
assets/*.png
!assets/repaint_result_plot3.png
!assets/repaint_result_plot4.png
!assets/repaint_result_plot5.png
!assets/repaint_result_plot6.png

# OS junk
.DS_Store
Thumbs.db

# IDE settings
.vscode/
.idea/

# Jupyter
.ipynb_checkpoints/

# Outputs folder content
outputs/*
!outputs/result_plots/
!outputs/schedule_plots/
!outputs/.gitkeep

# Temporary / misc
tree.txt
tree_repo.txt
tree_repo2.txt
tree_repo3.txt
repaint_simplified/tree_repaint.txt